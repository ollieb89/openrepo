{
  "meta": {
    "lastTouchedVersion": "2026.2.23",
    "lastTouchedAt": "2026-03-06T00:00:00.000Z"
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "google-gemini-cli/gemini-2.5-flash",
        "fallbacks": [
          "google-gemini-cli/gemini-3-pro-preview"
        ]
      },
      "models": {
        "google-gemini-cli/gemini-3-pro-preview": {
          "alias": "gemini-pro",
          "params": {
            "temperature": 0.4,
            "topP": 0.9
          }
        },
        "google-gemini-cli/gemini-2.5-flash": {
          "alias": "gemini-flash",
          "params": {
            "temperature": 0.7
          }
        }
      },
      "memorySearch": {
        "enabled": true
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8,
        "runTimeoutSeconds": 900
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 24000,
        "identifierPolicy": "strict"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h",
        "minPrunableToolChars": 50000
      },
      "blockStreamingDefault": "off",
      "typingMode": "instant",
      "typingIntervalSeconds": 6,
      "sandbox": {
        "mode": "non-main",
        "workspaceAccess": "none",
        "scope": "agent",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "network": "none",
          "memory": "1g"
        }
      },
      "imageMaxDimensionPx": 1200,
      "userTimezone": "UTC"
    },
    "list": [
      {
        "id": "main",
        "name": "Central Core",
        "level": 1,
        "reports_to": null,
        "orchestration": {}
      },
      {
        "id": "clawdia_prime",
        "name": "Head of Development",
        "sandbox": {
          "mode": "off"
        },
        "level": 1,
        "reports_to": null,
        "subordinates": [
          "pumplai_pm",
          "nextjs_pm",
          "python_backend_worker",
          "docs_pm"
        ],
        "orchestration": {
          "role": "strategic"
        }
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "text": true,
    "bash": false,
    "config": true,
    "debug": true,
    "restart": true,
    "allowFrom": {
      "*": [
        "owner_id_here"
      ]
    },
    "ownerDisplay": "raw"
  },
  "channels": {
    "defaults": {
      "groupPolicy": "allowlist",
      "heartbeat": {
        "showOk": false,
        "showAlerts": true,
        "useIndicator": true
      }
    },
    "telegram": {
      "enabled": true,
      "botToken": "${OPENCLAW_TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "historyLimit": 50,
      "mediaMaxMb": 5
    },
    "discord": {
      "enabled": false,
      "token": "${DISCORD_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "streaming": "off"
    },
    "slack": {
      "enabled": false,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "dmPolicy": "pairing"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "session": {
    "scope": "per-sender",
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4
    },
    "maintenance": {
      "mode": "warn",
      "pruneAfter": "30d"
    }
  },
  "messages": {
    "responsePrefix": "🦞",
    "ackReaction": "👀",
    "inbound": {
      "debounceMs": 2000
    },
    "tts": {
      "auto": "off",
      "provider": "openai"
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "./skills"
      ]
    },
    "install": {
      "nodeManager": "npm"
    }
  },
  "topology": {
    "proposal_confidence_warning_threshold": 5,
    "rubric_weights": {
      "complexity": 0.15,
      "coordination_overhead": 0.15,
      "risk_containment": 0.20,
      "time_to_first_output": 0.20,
      "cost_estimate": 0.10,
      "preference_fit": 0.20
    }
  },
  "plugins": {
    "slots": {
      "memory": "memory-memu"
    },
    "entries": {
      "memory-memu": {
        "enabled": true,
        "config": {
          "geminiApiKey": "${GEMINI_API_KEY}"
        }
      }
    }
  },
  "browser": {
    "enabled": true,
    "evaluateEnabled": true,
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    },
    "profiles": {
      "default": {
        "cdpPort": 18800
      }
    }
  }
}