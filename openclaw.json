{
  "meta": {
    "lastTouchedVersion": "2026.2.23",
    "lastTouchedAt": "2026-02-25T03:26:34.250Z"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google-gemini-cli/gemini-2.5-flash"
      },
      "models": {
        "google-gemini-cli/gemini-3-pro-preview": {
          "params": {
            "temperature": 0.4,
            "topP": 0.9
          }
        },
        "google-gemini-cli/gemini-2.5-flash": {
          "params": {
            "temperature": 0.7
          }
        }
      },
      "memorySearch": {
        "enabled": true
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "mode": "non-main",
        "workspaceAccess": "none",
        "scope": "session"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Central Core",
        "level": 1,
        "reports_to": null,
        "orchestration": {}
      },
      {
        "id": "clawdia_prime",
        "name": "Head of Development",
        "sandbox": {
          "mode": "off"
        },
        "level": 1,
        "reports_to": null,
        "subordinates": [
          "pumplai_pm",
          "nextjs_pm",
          "python_backend_worker",
          "docs_pm"
        ],
        "orchestration": {
          "role": "strategic"
        }
      },
      {
        "id": "pumplai_pm",
        "name": "PumpLAI Project Manager",
        "sandbox": {
          "mode": "all"
        },
        "level": 2,
        "reports_to": "clawdia_prime",
        "subordinates": [
          "l3_specialist"
        ],
        "orchestration": {
          "role": "tactical"
        }
      },
      {
        "id": "nextjs_pm",
        "name": "Frontend Architect",
        "sandbox": {
          "mode": "all"
        },
        "level": 2,
        "reports_to": "clawdia_prime",
        "subordinates": [
          "l3_specialist"
        ],
        "orchestration": {
          "role": "tactical"
        }
      },
      {
        "id": "python_backend_worker",
        "name": "ML Pipeline Worker",
        "sandbox": {
          "mode": "off"
        },
        "level": 2,
        "reports_to": "clawdia_prime",
        "subordinates": [
          "l3_specialist"
        ],
        "orchestration": {
          "role": "tactical"
        }
      },
      {
        "id": "l3_specialist",
        "name": "L3 Specialist Executor",
        "sandbox": {
          "mode": "all"
        },
        "level": 3,
        "reports_to": "pumplai_pm",
        "orchestration": {
          "container": {
            "image": "ubuntu:latest"
          }
        }
      },
      {
        "id": "agent",
        "name": "Dispatch Bridge",
        "sandbox": {
          "mode": "all"
        },
        "level": 3,
        "reports_to": "pumplai_pm",
        "orchestration": {
          "container": {
            "image": "ubuntu:latest"
          }
        }
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${OPENCLAW_TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "./skills"
      ]
    }
  },
  "topology": {
    "proposal_confidence_warning_threshold": 5,
    "rubric_weights": {
      "complexity": 0.15,
      "coordination_overhead": 0.15,
      "risk_containment": 0.20,
      "time_to_first_output": 0.20,
      "cost_estimate": 0.10,
      "preference_fit": 0.20
    }
  },
  "plugins": {
    "slots": {
      "memory": "memory-memu"
    },
    "entries": {
      "telegram": {
        "enabled": true
      },
      "google-gemini-cli-auth": {
        "enabled": true
      },
      "memory-memu": {
        "enabled": true,
        "config": {
          "geminiApiKey": "${GEMINI_API_KEY}"
        }
      }
    }
  }
}