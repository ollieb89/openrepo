  "agents": {
    "defaults": {
      "model": {
        "primary": "gpt-4o",
        "fallbacks": [
          "gpt-4o",
          "claude-3-5-sonnet",
          "gpt-4o-mini"
        ],
        "imageFallbacks": [
          "claude-3-5-sonnet",
          "gpt-4o"
        ]
      },
      "models": {
        "gpt-4o": {
          "params": {
            "temperature": 0.7
          },
          "aliases": [
            "gpt-4"
          ]
        },
        "gpt-4o-mini": {
          "params": {
            "temperature": 0.7
          }
        },
        "o1-preview": {
          "params": {}
        },
        "claude-3-5-sonnet": {
          "params": {
            "max_tokens": 4096
          },
          "aliases": [
            "claude-3-5"
          ]
        },
        "claude-3-haiku": {
          "params": {}
        },
        "gemini-1.5-pro": {
          "params": {},
          "aliases": [
            "gemini-pro"
          ]
        },
        "gemini-1.5-flash": {
          "params": {}
        },
        "llama-3-70b": {
          "params": {}
        },
        "llama-3-8b": {
          "params": {}
        },
        "mixtral-8x7b": {
          "params": {}
        }
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "mode": "non-main",
        "workspaceAccess": "none",
        "scope": "session"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Central Core",
        "level": 1,
        "sandbox": {
          "mode": "off"
        }
      }
    ]
  },
